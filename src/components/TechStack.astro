---
const languages = ['Go', 'C++', 'Python', 'TypeScript', 'Java', 'SQL'];
const tools = [
  'React',
  'Next.js',
  'Spring Boot',
  'PostgreSQL',
  'Redis',
  'Docker',
  'Kubernetes',
  'AWS',
  'Elasticsearch',
];
---

<section class="py-12">
  <div class="max-w-[1100px] mx-auto px-6">
    <h2 class="heading-24 mb-6">Tech I Love</h2>
    <div class="space-y-4">
      <div>
        <p
          class="label-13 text-[var(--text-secondary)] mb-2 uppercase tracking-wider"
        >
          Languages
        </p>
        <div class="flex flex-wrap gap-2">
          {
            languages.map(lang => (
              <span class="label-13 font-mono px-2.5 py-1 rounded-sm bg-[var(--bg-fill)] text-[var(--text-secondary)] border border-[var(--border)]">
                {lang}
              </span>
            ))
          }
        </div>
      </div>
      <div>
        <p
          class="label-13 text-[var(--text-secondary)] mb-2 uppercase tracking-wider"
        >
          Tools & Frameworks
        </p>
        <div class="flex flex-wrap gap-2">
          {
            tools.map(tool => (
              <span class="label-13 font-mono px-2.5 py-1 rounded-sm bg-[var(--bg-fill)] text-[var(--text-secondary)] border border-[var(--border)]">
                {tool}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
