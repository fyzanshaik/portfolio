---
import { env } from 'cloudflare:workers';

const TOKEN_TTL_MS = 60 * 60 * 1000;

function base64UrlEncode(bytes: ArrayBuffer): string {
  const binary = String.fromCharCode(...new Uint8Array(bytes));
  return btoa(binary)
    .replace(/\+/g, '-')
    .replace(/\//g, '_')
    .replace(/=+$/, '');
}

async function signToken(payload: string, secret: string): Promise<string> {
  const key = await crypto.subtle.importKey(
    'raw',
    new TextEncoder().encode(secret),
    { name: 'HMAC', hash: 'SHA-256' },
    false,
    ['sign']
  );
  const signature = await crypto.subtle.sign(
    'HMAC',
    key,
    new TextEncoder().encode(payload)
  );

  return `${payload}.${base64UrlEncode(signature)}`;
}

async function createScoreToken(): Promise<string> {
  const secret = (env as Record<string, unknown>).TIMER_GAME_API_KEY;
  if (typeof secret !== 'string') return '';

  const expiresAt = Date.now() + TOKEN_TTL_MS;
  const nonce = crypto.randomUUID();

  return signToken(`${expiresAt}.${nonce}`, secret);
}

const scoreToken = await createScoreToken();
---

<div
  class="timer-game-container relative w-full max-w-[min(252px,calc(100vw-2.5rem))] sm:max-w-[280px] md:max-w-[300px] lg:max-w-[280px]"
>
  <div class="flex flex-col gap-2">
    <div class="min-w-0 flex-1">
      <div
        class="mb-2 grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-2"
      >
        <div class="relative">
          <button
            id="game-info-button"
            aria-label="Game instructions"
            class="flex h-8 w-8 items-center justify-center rounded-sm text-[var(--text-secondary)] transition-colors hover:bg-[var(--bg-fill)] hover:text-[var(--text-primary)]"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </button>
          <div
            id="game-info-tooltip"
            class="absolute bottom-full left-0 z-10 mb-2 hidden w-[min(280px,calc(100vw-3rem))] rounded-md border border-[var(--border)] bg-[var(--bg-surface)] px-3 py-2 text-left copy-14 text-[var(--text-secondary)] shadow-lg"
          >
            <p class="font-medium text-[var(--text-primary)]">How to play</p>
            <p>1. Click the box to start.</p>
            <p>2. Click again to stop.</p>
            <p>3. Get as close to the target time as you can.</p>
          </div>
        </div>
        <div class="relative min-w-0">
          <input
            type="text"
            id="player-name"
            placeholder="Your name"
            maxlength="12"
            class="h-8 w-full rounded-sm border border-[var(--border)] bg-transparent px-2.5 pr-8 label-13 text-[var(--text-primary)] placeholder:text-[var(--text-tertiary)] transition-colors focus:border-[var(--accent)] focus:outline-none"
          />
          <button
            id="save-name-btn"
            aria-label="Save name"
            class="pointer-events-none absolute right-0.5 top-1/2 -translate-y-1/2 rounded-sm p-1.5 text-[var(--text-secondary)] opacity-0 transition-colors hover:bg-[var(--bg-fill)]"
            title="Save name"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </button>
        </div>
        <button
          id="open-leaderboard"
          class="h-8 whitespace-nowrap rounded-sm px-2 label-13 text-[var(--text-secondary)] transition-colors hover:bg-[var(--bg-fill)] hover:text-[var(--text-primary)]"
        >
          Leaderboard ↗
        </button>
      </div>

      <div
        id="game-box"
        role="button"
        tabindex="0"
        aria-label="Start timer game"
        class="relative h-36 cursor-pointer select-none overflow-hidden rounded-lg border border-[var(--border)] transition-colors hover:border-[var(--border-hover)] sm:aspect-square sm:h-auto"
      >
        <div
          class="pointer-events-none absolute left-3 top-3 z-[1] text-left label-12 text-[var(--text-tertiary)]"
        >
          <span class="block">Best error</span>
          <span
            id="your-score"
            class="block tabular text-[var(--text-secondary)]">—</span
          >
        </div>
        <div
          class="pointer-events-none absolute right-3 top-3 z-[1] text-right label-12 text-[var(--text-tertiary)]"
        >
          <span class="block">Global best</span>
          <span id="high-score" class="block tabular text-[var(--accent)]"
            >—</span
          >
        </div>

        <div
          id="state-idle"
          class="absolute inset-0 flex flex-col items-center justify-center"
        >
          <span
            class="text-2xl tabular text-[var(--accent)] sm:text-3xl"
            id="target-time-display">1s</span
          >
          <span class="mt-1.5 label-13 text-[var(--text-secondary)] sm:mt-2"
            >Click to start</span
          >
        </div>

        <div
          id="state-running"
          class="absolute inset-0 flex items-center justify-center hidden"
        >
          <span
            id="random-display"
            class="text-3xl tabular text-[var(--text-secondary)] sm:text-4xl"
            >0.000</span
          >
        </div>

        <div
          id="state-result"
          class="absolute inset-0 flex flex-col items-center justify-center hidden"
        >
          <span class="label-13 text-[var(--text-secondary)] mb-1"
            >Your time</span
          >
          <span
            id="result-time"
            class="text-2xl tabular text-[var(--text-primary)] sm:text-3xl"
            >0.000s</span
          >
          <span id="result-diff" class="text-sm tabular mt-1"></span>
          <span
            id="game-status"
            class="label-13 text-[var(--text-secondary)] mt-1"
            aria-live="polite"></span>
          <span
            id="new-best-indicator"
            class="label-13 text-[var(--accent)] mt-1 hidden">New best!</span
          >
          <span class="label-13 text-[var(--text-secondary)] mt-3"
            >Click to retry</span
          >
        </div>
      </div>

      <div
        class="mt-1.5 flex items-center justify-center gap-1.5 sm:mt-2 sm:gap-2"
      >
        <button
          id="mode-prev"
          aria-label="Previous mode"
          class="p-1.5 text-[var(--text-secondary)] rounded-sm hover:bg-[var(--bg-fill)] transition-colors"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <div class="flex gap-1">
          <button
            data-mode="1"
            class="mode-btn h-8 rounded-sm bg-[var(--accent)]/10 px-2.5 label-13 tabular text-[var(--accent)] transition-colors"
            >1s</button
          >
          <button
            data-mode="5"
            class="mode-btn h-8 rounded-sm px-2.5 label-13 tabular text-[var(--text-secondary)] transition-colors hover:bg-[var(--bg-fill)]"
            >5s</button
          >
          <button
            data-mode="10"
            class="mode-btn h-8 rounded-sm px-2.5 label-13 tabular text-[var(--text-secondary)] transition-colors hover:bg-[var(--bg-fill)]"
            >10s</button
          >
          <button
            data-mode="15"
            class="mode-btn h-8 rounded-sm px-2.5 label-13 tabular text-[var(--text-secondary)] transition-colors hover:bg-[var(--bg-fill)]"
            >15s</button
          >
        </div>
        <button
          id="mode-next"
          aria-label="Next mode"
          class="p-1.5 text-[var(--text-secondary)] rounded-sm hover:bg-[var(--bg-fill)] transition-colors"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="leaderboard" class="hidden"></div>
  <p
    id="player-count"
    class="mt-2 text-center label-12 text-[var(--text-tertiary)]"
  >
    — players
  </p>
  <span id="welcome-msg" class="hidden"></span>

  <!-- Leaderboard Modal -->
  <div
    id="leaderboard-modal"
    class="fixed inset-0 z-50 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="leaderboard-title"
  >
    <div
      class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity duration-300 ease-[var(--ease-geist)]"
      id="modal-backdrop"
    >
    </div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 max-h-[80vh] bg-[var(--bg-primary)] border border-[var(--border)] rounded-md shadow-xl overflow-hidden"
    >
      <div
        class="p-4 border-b border-[var(--border)] flex items-center justify-between"
      >
        <h3
          id="leaderboard-title"
          class="heading-16 text-[var(--text-primary)]"
        >
          Leaderboard
        </h3>
        <button
          id="close-modal"
          aria-label="Close"
          class="p-1.5 text-[var(--text-secondary)] rounded-sm hover:bg-[var(--bg-fill)] transition-colors"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <div class="p-4">
        <div class="flex items-center justify-center gap-3 mb-4">
          <button
            id="modal-mode-prev"
            aria-label="Previous mode"
            class="p-1.5 text-[var(--text-secondary)] rounded-sm hover:bg-[var(--bg-fill)] transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>
          <span
            id="modal-mode-display"
            class="text-lg tabular text-[var(--accent)]">1s</span
          >
          <button
            id="modal-mode-next"
            aria-label="Next mode"
            class="p-1.5 text-[var(--text-secondary)] rounded-sm hover:bg-[var(--bg-fill)] transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <div id="modal-leaderboard" class="space-y-2 max-h-60 overflow-y-auto">
          <div class="copy-14 text-[var(--text-secondary)] text-center">
            Loading…
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ scoreToken }}>
  function generateAnonName() {
    const num = Math.floor(Math.random() * 99999)
      .toString()
      .padStart(5, '0');
    return `anon${num}`;
  }

  const modes = [1, 5, 10, 15];
  let currentModeIndex = 0;
  let modalModeIndex = 0;
  let gameState = 'idle';
  let startTime = 0;
  let activeMode = modes[currentModeIndex];
  let activeRoundId = 0;
  let randomInterval = null;
  let isSaving = false;
  let activeScoreToken = scoreToken;
  let lastFocusedElement = null;
  let userScoresCache = {};
  let nameTypingTimeout = null;
  let isNewUser = true;
  let fullLeaderboardCache = {};
  let scoresRequestId = 0;
  let modalRequestId = 0;

  const gameBox = document.getElementById('game-box');
  const stateIdle = document.getElementById('state-idle');
  const stateRunning = document.getElementById('state-running');
  const stateResult = document.getElementById('state-result');
  const targetTimeDisplay = document.getElementById('target-time-display');
  const randomDisplay = document.getElementById('random-display');
  const resultTime = document.getElementById('result-time');
  const resultDiff = document.getElementById('result-diff');
  const newBestIndicator = document.getElementById('new-best-indicator');
  const yourScore = document.getElementById('your-score');
  const highScore = document.getElementById('high-score');
  const leaderboard = document.getElementById('leaderboard');
  const playerCount = document.getElementById('player-count');
  const gameStatus = document.getElementById('game-status');
  const playerNameInput = document.getElementById('player-name');
  const saveNameBtn = document.getElementById('save-name-btn');
  const welcomeMsg = document.getElementById('welcome-msg');
  const modeBtns = document.querySelectorAll('.mode-btn');
  const modePrev = document.getElementById('mode-prev');
  const modeNext = document.getElementById('mode-next');

  const leaderboardModal = document.getElementById('leaderboard-modal');
  const modalBackdrop = document.getElementById('modal-backdrop');
  const closeModalBtn = document.getElementById('close-modal');
  const openLeaderboardBtn = document.getElementById('open-leaderboard');
  const modalModeDisplay = document.getElementById('modal-mode-display');
  const modalModePrev = document.getElementById('modal-mode-prev');
  const modalModeNext = document.getElementById('modal-mode-next');
  const modalLeaderboard = document.getElementById('modal-leaderboard');

  const playerId = (() => {
    const key = 'timer-game-player-id';
    let id = localStorage.getItem(key);
    if (!id) {
      id = crypto.randomUUID();
      localStorage.setItem(key, id);
    }
    return id;
  })();

  function formatDuration(milliseconds) {
    return `${(milliseconds / 1000).toFixed(3)}s`;
  }

  function escapeHtml(value) {
    const element = document.createElement('span');
    element.textContent = value;
    return element.innerHTML;
  }

  function playGameSound() {
    if (window.AudioUX && !window.AudioUX.isMuted()) {
      window.AudioUX.playTheme();
    }
  }

  function getUsername() {
    return (
      playerNameInput.value.trim() ||
      localStorage.getItem('timer-game-username') ||
      ''
    );
  }

  function saveUsername(name) {
    name = name.slice(0, 12).replace(/[^a-zA-Z0-9_-]/g, '');
    if (name && name !== 'anon') {
      playerNameInput.value = name;
      localStorage.setItem('timer-game-username', name);
      saveNameBtn.classList.remove('opacity-0');
      saveNameBtn.classList.remove('pointer-events-none');
      saveNameBtn.classList.add('pointer-events-auto');
      saveNameBtn.classList.add('text-[var(--accent)]');
      setTimeout(() => {
        saveNameBtn.classList.add('opacity-0');
        saveNameBtn.classList.add('pointer-events-none');
        saveNameBtn.classList.remove('pointer-events-auto');
        saveNameBtn.classList.remove('text-[var(--accent)]');
      }, 1500);
      return true;
    }
    return false;
  }

  function loadSavedUsername() {
    const saved = localStorage.getItem('timer-game-username');
    if (saved) {
      playerNameInput.value = saved;
    }
  }

  function showSaveButton() {
    saveNameBtn.classList.remove('opacity-0');
    saveNameBtn.classList.remove('pointer-events-none');
    saveNameBtn.classList.add('pointer-events-auto');
  }

  function hideSaveButton() {
    saveNameBtn.classList.add('opacity-0');
    saveNameBtn.classList.add('pointer-events-none');
    saveNameBtn.classList.remove('pointer-events-auto');
  }

  function updateWelcomeMessage(name, isNew) {
    if (name && isNew) {
      welcomeMsg.textContent = `Hi ${name}!`;
      welcomeMsg.classList.add('text-[var(--accent)]');
    } else {
      welcomeMsg.textContent = 'Leaderboard';
      welcomeMsg.classList.remove('text-[var(--accent)]');
    }
  }

  function refreshGameData() {
    fetchScores();
    if (!leaderboardModal.classList.contains('hidden')) {
      renderModalLeaderboard();
    }
  }

  function openModal() {
    lastFocusedElement = document.activeElement;
    modalModeIndex = currentModeIndex;
    updateModalModeDisplay();
    fetchModalLeaderboard();
    leaderboardModal.classList.remove('hidden');
    closeModalBtn.focus();
    playGameSound();
  }

  function closeModal() {
    leaderboardModal.classList.add('hidden');
    lastFocusedElement?.focus();
    playGameSound();
  }

  function updateModalModeDisplay() {
    modalModeDisplay.textContent = `${modes[modalModeIndex]}s`;
  }

  async function fetchModalLeaderboard() {
    const mode = modes[modalModeIndex];
    const requestId = ++modalRequestId;
    modalLeaderboard.innerHTML =
      '<div class="copy-14 text-[var(--text-secondary)] text-center">Loading…</div>';

    try {
      const response = await fetch(
        `/api/timer-game?mode=${mode}&playerId=${encodeURIComponent(playerId)}`
      );
      if (!response.ok) return;

      const data = await response.json();
      if (requestId !== modalRequestId || mode !== modes[modalModeIndex])
        return;

      fullLeaderboardCache[mode.toString()] = [
        ...(data.leaderboard || []),
        ...(data.legacyEntries || []),
      ];

      renderModalLeaderboard();
    } catch (error) {
      if (requestId !== modalRequestId || mode !== modes[modalModeIndex])
        return;

      console.error('Failed to fetch leaderboard:', error);
      modalLeaderboard.innerHTML =
        '<div class="copy-14 text-[var(--text-secondary)] text-center">Could not load scores. Try again.</div>';
    }
  }

  function renderModalLeaderboard() {
    const mode = modes[modalModeIndex];
    const entries = fullLeaderboardCache[mode.toString()] || [];
    const username = getUsername();

    if (entries.length === 0) {
      modalLeaderboard.innerHTML =
        '<div class="copy-14 text-[var(--text-secondary)] text-center py-4">No scores yet. Play a round to set one.</div>';
      return;
    }

    modalLeaderboard.innerHTML = entries
      .map((entry, i) => {
        const isCurrentUser = entry.name === username;
        const rankColor =
          i === 0
            ? 'text-[var(--accent)]'
            : i === 1
              ? 'text-yellow-400'
              : i === 2
                ? 'text-orange-400'
                : 'text-[var(--text-secondary)]';
        const bgClass = isCurrentUser ? 'bg-[var(--accent)]/10' : '';

        return `
        <div class="flex items-center justify-between py-2 px-3 rounded-sm ${bgClass}">
          <div class="flex items-center gap-3">
            <span class="text-sm tabular ${rankColor} w-5">#${i + 1}</span>
            <span class="text-sm ${isCurrentUser ? 'text-[var(--accent)]' : 'text-[var(--text-primary)]'}">${escapeHtml(entry.name)}${entry.isFlaggedLegacy ? ' <span class="ml-1 text-xs text-red-400">Cheater</span>' : ''}</span>
          </div>
          <span class="text-sm tabular text-[var(--text-secondary)]">${formatDuration(entry.errorMs)}</span>
        </div>
      `;
      })
      .join('');
  }

  openLeaderboardBtn.addEventListener('click', e => {
    e.stopPropagation();
    openModal();
  });

  closeModalBtn.addEventListener('click', e => {
    e.stopPropagation();
    closeModal();
  });

  modalBackdrop.addEventListener('click', e => {
    e.stopPropagation();
    closeModal();
  });

  modalModePrev.addEventListener('click', e => {
    e.stopPropagation();
    modalModeIndex = (modalModeIndex - 1 + modes.length) % modes.length;
    updateModalModeDisplay();
    fetchModalLeaderboard();
    playGameSound();
  });

  modalModeNext.addEventListener('click', e => {
    e.stopPropagation();
    modalModeIndex = (modalModeIndex + 1) % modes.length;
    updateModalModeDisplay();
    fetchModalLeaderboard();
    playGameSound();
  });

  playerNameInput.addEventListener('input', () => {
    showSaveButton();

    if (nameTypingTimeout) {
      clearTimeout(nameTypingTimeout);
    }

    nameTypingTimeout = setTimeout(() => {
      const name = playerNameInput.value.trim();
      if (name && saveUsername(name)) {
        refreshGameData();
      }
    }, 3000);
  });

  playerNameInput.addEventListener('blur', () => {
    if (nameTypingTimeout) {
      clearTimeout(nameTypingTimeout);
      nameTypingTimeout = null;
    }
    const name = playerNameInput.value.trim();
    if (name && saveUsername(name)) {
      refreshGameData();
    }
    hideSaveButton();
  });

  playerNameInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      if (nameTypingTimeout) {
        clearTimeout(nameTypingTimeout);
        nameTypingTimeout = null;
      }
      const name = playerNameInput.value.trim();
      if (name && saveUsername(name)) {
        refreshGameData();
      }
      playerNameInput.blur();
    }
  });

  saveNameBtn.addEventListener('click', e => {
    e.stopPropagation();
    if (nameTypingTimeout) {
      clearTimeout(nameTypingTimeout);
      nameTypingTimeout = null;
    }
    const name = playerNameInput.value.trim();
    if (name && saveUsername(name)) {
      refreshGameData();
    }
    playGameSound();
  });

  function updateModeDisplay() {
    const targetSeconds = modes[currentModeIndex];
    targetTimeDisplay.textContent = `${targetSeconds}s`;

    modeBtns.forEach(btn => {
      const mode = parseInt(btn.dataset.mode || '0');
      if (mode === targetSeconds) {
        btn.classList.add('text-[var(--accent)]', 'bg-[var(--accent)]/10');
        btn.classList.remove('text-[var(--text-secondary)]');
      } else {
        btn.classList.remove('text-[var(--accent)]', 'bg-[var(--accent)]/10');
        btn.classList.add('text-[var(--text-secondary)]');
      }
    });

    updateYourScoreDisplay();
  }

  function updateYourScoreDisplay() {
    const mode = modes[currentModeIndex].toString();
    const score = userScoresCache[mode];
    yourScore.textContent = score !== undefined ? formatDuration(score) : '—';
  }

  function switchState(newState) {
    gameState = newState;
    stateIdle.classList.toggle('hidden', newState !== 'idle');
    stateRunning.classList.toggle('hidden', newState !== 'running');
    stateResult.classList.toggle('hidden', newState !== 'result');
    if (newState !== 'result') {
      newBestIndicator.classList.add('hidden');
    }
  }

  function generateRandomDisplay() {
    randomDisplay.textContent = formatDuration(
      Math.round(performance.now() - startTime)
    );
  }

  function startGame() {
    playGameSound();
    startTime = performance.now();
    activeMode = modes[currentModeIndex];
    activeRoundId += 1;
    switchState('running');
    randomInterval = setInterval(generateRandomDisplay, 50);
  }

  async function stopGame() {
    if (randomInterval) {
      clearInterval(randomInterval);
      randomInterval = null;
    }

    const endTime = performance.now();
    const elapsedMs = Math.round(endTime - startTime);
    const targetSeconds = activeMode;
    const roundId = activeRoundId;
    const diffMs = elapsedMs - targetSeconds * 1000;
    const absDiff = Math.abs(diffMs);

    playGameSound();

    resultTime.textContent = formatDuration(elapsedMs);

    if (diffMs > 0) {
      resultDiff.textContent = `${formatDuration(absDiff)} late`;
      resultDiff.className = 'text-sm tabular mt-1 text-red-400';
    } else if (diffMs < 0) {
      resultDiff.textContent = `${formatDuration(absDiff)} early`;
      resultDiff.className = 'text-sm tabular mt-1 text-yellow-400';
    } else {
      resultDiff.textContent = 'Perfect!';
      resultDiff.className = 'text-sm tabular mt-1 text-[var(--accent)]';
    }

    switchState('result');

    const currentBest = userScoresCache[targetSeconds.toString()];
    const isBetter = currentBest === undefined || absDiff < currentBest;

    if (isBetter) {
      isSaving = true;
      gameStatus.textContent = 'Saving…';
      await submitScore(absDiff, targetSeconds, roundId);
      isSaving = false;
    }
  }

  async function submitScore(score, targetSeconds, roundId) {
    let name = getUsername();
    const needsAnonName = !name;
    if (!name) name = generateAnonName();

    try {
      const response = await fetch('/api/timer-game', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          name,
          errorMs: score,
          mode: targetSeconds,
          playerId,
          scoreToken: activeScoreToken,
        }),
      });

      let data = await response.json();
      if (response.status === 403) {
        const tokenResponse = await fetch('/api/timer-game?token=1');
        const tokenData = await tokenResponse.json();
        if (tokenData.scoreToken) {
          activeScoreToken = tokenData.scoreToken;
          return submitScore(score, targetSeconds, roundId);
        }
      }

      if (response.ok && data.saved) {
        if (roundId !== activeRoundId || gameState !== 'result') return;

        const finalName = data.assignedName || name;
        newBestIndicator.classList.remove('hidden');
        if (needsAnonName) {
          saveUsername(finalName);
          playerNameInput.value = finalName;
        }
        userScoresCache[targetSeconds.toString()] = data.currentBest;
        isNewUser = false;
        updateYourScoreDisplay();
        updateWelcomeMessage(finalName, false);
        await fetchScores();
        gameStatus.textContent = 'Saved.';
      } else if (roundId === activeRoundId && gameState === 'result') {
        gameStatus.textContent = data.error || 'Your score was not saved.';
      }
    } catch (error) {
      console.error('Failed to save score:', error);
      gameStatus.textContent = 'Could not save your score. Try again.';
    }
  }

  async function fetchScores() {
    const targetSeconds = modes[currentModeIndex];
    const requestId = ++scoresRequestId;
    const username = getUsername();

    const url = `/api/timer-game?mode=${targetSeconds}&playerId=${encodeURIComponent(playerId)}`;

    try {
      const response = await fetch(url);
      if (!response.ok) return;

      const data = await response.json();
      if (
        requestId !== scoresRequestId ||
        targetSeconds !== modes[currentModeIndex]
      ) {
        return;
      }

      if (data.highScore !== null && data.highScore !== undefined) {
        highScore.textContent = formatDuration(data.highScore);
      } else {
        highScore.textContent = '—';
      }

      if (data.userScores && Object.keys(data.userScores).length > 0) {
        userScoresCache = data.userScores;
        updateYourScoreDisplay();
      }

      isNewUser = Object.keys(data.userScores || {}).length === 0;
      updateWelcomeMessage(username, isNewUser);

      fullLeaderboardCache[targetSeconds.toString()] = data.leaderboard || [];
      playerCount.textContent = `${data.playerCount || 0} players`;

      if (data.leaderboard && data.leaderboard.length > 0) {
        leaderboard.innerHTML = data.leaderboard
          .slice(0, 3)
          .map(
            (entry, i) =>
              `<div class="${i === 0 ? 'text-[var(--accent)]' : 'text-[var(--text-secondary)]'}">${escapeHtml(entry.name)}: ${formatDuration(entry.errorMs)}</div>`
          )
          .join('');
      } else {
        leaderboard.innerHTML =
          '<div class="text-[var(--text-secondary)]">No scores yet. Play a round to set one.</div>';
      }
    } catch (error) {
      if (
        requestId !== scoresRequestId ||
        targetSeconds !== modes[currentModeIndex]
      ) {
        return;
      }

      console.error('Failed to fetch scores:', error);
      leaderboard.innerHTML =
        '<div class="text-[var(--text-secondary)]">—</div>';
    }
  }

  gameBox.addEventListener('click', e => {
    e.stopPropagation();

    if (isSaving) return;

    if (gameState === 'idle') {
      startGame();
    } else if (gameState === 'running') {
      stopGame();
    } else if (gameState === 'result') {
      activeRoundId += 1;
      switchState('idle');
    }
  });

  gameBox.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      gameBox.click();
    }
  });

  document.addEventListener('visibilitychange', () => {
    if (document.hidden && gameState === 'running') {
      clearInterval(randomInterval);
      randomInterval = null;
      switchState('idle');
      gameStatus.textContent = 'Round cancelled because the tab was inactive.';
    }
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Tab' && !leaderboardModal.classList.contains('hidden')) {
      const focusable = leaderboardModal.querySelectorAll(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
    if (e.key === 'Escape' && !leaderboardModal.classList.contains('hidden'))
      closeModal();
  });

  modePrev.addEventListener('click', e => {
    e.stopPropagation();
    if (gameState !== 'idle') return;
    currentModeIndex = (currentModeIndex - 1 + modes.length) % modes.length;
    updateModeDisplay();
    fetchScores();
    playGameSound();
  });

  modeNext.addEventListener('click', e => {
    e.stopPropagation();
    if (gameState !== 'idle') return;
    currentModeIndex = (currentModeIndex + 1) % modes.length;
    updateModeDisplay();
    fetchScores();
    playGameSound();
  });

  modeBtns.forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      if (gameState !== 'idle') return;
      const mode = parseInt(btn.dataset.mode || '0');
      currentModeIndex = modes.indexOf(mode);
      updateModeDisplay();
      fetchScores();
      playGameSound();
    });
  });

  loadSavedUsername();
  updateModeDisplay();
  fetchScores();

  // Cleanup intervals when navigating away (View Transitions)
  document.addEventListener('astro:before-swap', () => {
    if (randomInterval) {
      clearInterval(randomInterval);
      randomInterval = null;
    }
    if (nameTypingTimeout) {
      clearTimeout(nameTypingTimeout);
      nameTypingTimeout = null;
    }
  });
</script>

<script>
  function setupInfoTooltip() {
    const infoButton = document.getElementById('game-info-button');
    const infoTooltip = document.getElementById('game-info-tooltip');

    if (infoButton && infoTooltip && !infoButton.dataset.tooltipSetup) {
      infoButton.dataset.tooltipSetup = 'true';

      infoButton.addEventListener('click', event => {
        event.stopPropagation();
        infoTooltip.classList.toggle('hidden');
      });

      document.addEventListener('click', event => {
        if (
          !infoTooltip.classList.contains('hidden') &&
          !infoButton.contains(event.target as Node) &&
          !infoTooltip.contains(event.target as Node)
        ) {
          infoTooltip.classList.add('hidden');
        }
      });
    }
  }

  // Run on initial load and View Transitions navigation
  setupInfoTooltip();
  document.addEventListener('astro:page-load', setupInfoTooltip);
</script>
