---
const GITHUB_USERNAME = 'fyzanshaik';
---

<section>
  <div class="max-w-[1100px] mx-auto px-6">
    <div class="flex items-center justify-between mb-6">
      <h2 class="heading-24">Activity</h2>
      <a
        href={`https://github.com/${GITHUB_USERNAME}`}
        target="_blank"
        rel="noopener noreferrer"
        class="label-13 text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors flex items-center gap-1"
      >
        View GitHub
        <svg
          class="w-3 h-3"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <div id="github-contributions" class="hidden mb-7">
      <p class="mb-2 label-13 tabular text-[var(--text-tertiary)]">
        Open-source contributions
      </p>
      <div id="github-contribution-badges" class="flex flex-wrap gap-2"></div>
    </div>

    <div id="github-activity-list" class="space-y-4">
      <div class="animate-pulse space-y-4">
        <div class="flex flex-col md:flex-row md:items-baseline gap-1 md:gap-8">
          <div class="h-3 bg-[var(--bg-fill)] rounded-md w-[100px]"></div>
          <div class="flex-1">
            <div class="h-4 bg-[var(--bg-fill)] rounded-md w-3/4 mb-1"></div>
            <div class="h-3 bg-[var(--bg-fill)] rounded-md w-1/2"></div>
          </div>
        </div>
        <div class="flex flex-col md:flex-row md:items-baseline gap-1 md:gap-8">
          <div class="h-3 bg-[var(--bg-fill)] rounded-md w-[100px]"></div>
          <div class="flex-1">
            <div class="h-4 bg-[var(--bg-fill)] rounded-md w-2/3 mb-1"></div>
            <div class="h-3 bg-[var(--bg-fill)] rounded-md w-1/3"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const CACHE_KEY = 'github-pr-activity-cache-v11';
  const CACHE_TTL = 5 * 60 * 1000; // 5 minutes
  const PERSONAL_GITHUB_USERNAME = 'fyzanshaik';
  const WORK_GITHUB_USERNAME = 'fyzanshaik-atlan';
  const WORK_GITHUB_ORGANIZATION = 'atlanhq';
  const EXCLUDED_CONTRIBUTION_OWNERS = new Set([
    'anuragts',
    'g-aniketh',
    'coxistai-team',
  ]);
  const FEATURED_CONTRIBUTION_ORGANIZATIONS = [
    {
      login: 'NousResearch',
      html_url: 'https://github.com/NousResearch',
    },
    {
      login: 'atlanhq',
      html_url: 'https://github.com/atlanhq',
    },
  ];

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function getRepository(pr) {
    try {
      const parts = new URL(pr.repository_url).pathname
        .split('/')
        .filter(Boolean);
      const [owner, name] = parts.slice(-2);
      if (!owner || !name) return null;

      return {
        owner,
        name,
        fullName: `${owner}/${name}`,
        url: `https://github.com/${owner}/${name}`,
      };
    } catch {
      return null;
    }
  }

  function getExternalPullRequests(items) {
    return (items || []).filter(pr => {
      const repository = getRepository(pr);
      return (
        repository &&
        repository.owner.toLowerCase() !==
          PERSONAL_GITHUB_USERNAME.toLowerCase()
      );
    });
  }

  function getWorkPullRequests(items) {
    return (items || [])
      .filter(pr => {
        const repository = getRepository(pr);
        return (
          repository &&
          repository.owner.toLowerCase() ===
            WORK_GITHUB_ORGANIZATION.toLowerCase()
        );
      })
      .map(pr => ({ ...pr, isWorkPullRequest: true }));
  }

  function getCachedData() {
    try {
      const cached = sessionStorage.getItem(CACHE_KEY);
      if (cached) {
        const { data, timestamp } = JSON.parse(cached);
        if (Date.now() - timestamp < CACHE_TTL) {
          return data;
        }
      }
    } catch (e) {
      // Ignore cache errors
    }
    return null;
  }

  function setCachedData(data) {
    try {
      sessionStorage.setItem(
        CACHE_KEY,
        JSON.stringify({
          data,
          timestamp: Date.now(),
        })
      );
    } catch (e) {
      // Ignore cache errors
    }
  }

  function renderActivity(items) {
    const listEl = document.getElementById('github-activity-list');
    if (!listEl) return;

    if (items && items.length > 0) {
      listEl.innerHTML = items
        .slice(0, 5)
        .map(pr => {
          const date = new Date(pr.closed_at).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });

          const repository = getRepository(pr);
          if (!repository) return '';

          return `
          <div class="group">
            <a href="${pr.html_url}" target="_blank" rel="noopener" class="block">
              <div class="flex flex-col md:flex-row md:items-baseline gap-1 md:gap-8">
                <span class="label-13 tabular text-[var(--text-secondary)] whitespace-nowrap w-[100px]">${date}</span>
                <div class="flex-1">
                  <div class="flex flex-wrap items-baseline gap-2 mb-1">
                    <span class="heading-16 group-hover:text-[var(--accent)] transition-colors">${escapeHtml(pr.title)}</span>
                    <span class="label-12 font-mono text-[var(--text-secondary)] px-1.5 py-0.5 rounded-sm bg-[var(--bg-fill)] border border-[var(--border)]">${escapeHtml(repository.fullName)}</span>
                    ${pr.isWorkPullRequest ? '<span class="label-12 font-mono text-[var(--accent)]">Work PR</span>' : ''}
                  </div>
                </div>
              </div>
            </a>
          </div>
        `;
        })
        .join('');
    } else {
      listEl.innerHTML =
        '<p class="copy-14 text-[var(--text-secondary)]">No recent activity.</p>';
    }
  }

  function renderContributionOrganizations(pullRequests) {
    const section = document.getElementById('github-contributions');
    const badgesEl = document.getElementById('github-contribution-badges');
    if (!section || !badgesEl) return;

    const repositories = (pullRequests || [])
      .map(getRepository)
      .filter(Boolean);

    const contributionOrganizations = [
      ...repositories.map(repository => ({
        login: repository.owner,
        html_url: `https://github.com/${repository.owner}`,
      })),
      ...FEATURED_CONTRIBUTION_ORGANIZATIONS,
    ];

    const organizations = [
      ...new Map(
        contributionOrganizations.map(organization => [
          organization.login.toLowerCase(),
          organization,
        ])
      ).values(),
    ].filter(organization => {
      const owner = organization.login.toLowerCase();
      return (
        owner !== PERSONAL_GITHUB_USERNAME.toLowerCase() &&
        !EXCLUDED_CONTRIBUTION_OWNERS.has(owner)
      );
    });

    if (!organizations?.length) {
      section.classList.add('hidden');
      badgesEl.replaceChildren();
      return;
    }

    badgesEl.innerHTML = organizations
      .sort((a, b) => a.login.localeCompare(b.login))
      .map(
        organization => `
          <a href="${escapeHtml(organization.html_url)}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-md border border-[var(--border)] bg-[var(--bg-surface)] px-2 py-1.5 font-mono label-12 text-[var(--text-secondary)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]">
            <img src="https://github.com/${encodeURIComponent(organization.login)}.png?size=48" alt="" width="20" height="20" class="size-5 rounded-sm bg-[var(--bg-fill)]" loading="lazy" />
            <span>@${escapeHtml(organization.login)}</span>
          </a>
        `
      )
      .join('');
    section.classList.remove('hidden');
  }

  async function loadGitHubActivity() {
    const listEl = document.getElementById('github-activity-list');
    if (!listEl) return;

    // Check cache first
    const cachedData = getCachedData();
    if (cachedData) {
      renderActivity(cachedData.activityPullRequests);
      renderContributionOrganizations(cachedData.contributionPullRequests);
      return;
    }

    try {
      const [personalResponse, workResponse] = await Promise.all([
        fetch(
          `https://api.github.com/search/issues?q=author:${PERSONAL_GITHUB_USERNAME}+type:pr+is:merged&sort=updated&per_page=100`
        ),
        fetch(
          `https://api.github.com/search/issues?q=author:${WORK_GITHUB_USERNAME}+type:pr+is:merged&sort=updated&per_page=100`
        ),
      ]);

      if (!personalResponse.ok) throw new Error('Failed to fetch activity');

      const personalData = await personalResponse.json();
      const workData = workResponse.ok
        ? await workResponse.json()
        : { items: [] };

      const externalPullRequests = getExternalPullRequests(personalData.items);
      const workPullRequests = getWorkPullRequests(workData.items);
      const byMostRecent = (a, b) =>
        new Date(b.closed_at) - new Date(a.closed_at);
      const activityPullRequests = [
        ...workPullRequests.sort(byMostRecent).slice(0, 3),
        ...externalPullRequests.sort(byMostRecent).slice(0, 2),
      ].sort(byMostRecent);
      const contributionPullRequests = [
        ...externalPullRequests,
        ...workPullRequests,
      ];

      // The activity feed reserves three recent rows for work and two for
      // personal open source, so either account cannot crowd out the other.
      // NousResearch is included separately because its maintainer explicitly
      // cherry-picked and credited the original PR.
      setCachedData({ activityPullRequests, contributionPullRequests });

      renderActivity(activityPullRequests);
      renderContributionOrganizations(contributionPullRequests);
    } catch (error) {
      console.error(error);
      if (listEl) listEl.innerHTML = ''; // Silently fail
    }
  }

  // Run on initial load and View Transitions navigation
  loadGitHubActivity();
  document.addEventListener('astro:page-load', loadGitHubActivity);
</script>
