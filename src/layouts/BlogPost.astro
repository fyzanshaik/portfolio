---
import { ClientRouter } from 'astro:transitions';
import NavBar from '../components/NavBar.astro';
import AudioSystem from '../components/AudioSystem.astro';
import '../styles/global.css';

const { frontmatter } = Astro.props;
const pageUrl = `https://fyzanshaik.in${Astro.url.pathname}`;

const ogImage = frontmatter.ogImage
  ? frontmatter.ogImage.startsWith('http')
    ? frontmatter.ogImage
    : `https://fyzanshaik.in${frontmatter.ogImage}`
  : `https://fyzanshaik.in/favicon.png`;

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}

const GA_ID = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0a0a0a"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={pageUrl} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt" />

    <title>{frontmatter.title} | Faizan Shaik</title>
    <meta name="description" content={frontmatter.description} />
    <meta name="keywords" content={frontmatter.tags?.join(', ')} />
    <meta name="author" content="Faizan Shaik" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta
      name="article:published_time"
      content={new Date(frontmatter.date).toISOString()}
    />
    <meta name="article:author" content="Faizan Shaik" />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={frontmatter.title} />
    <meta property="og:description" content={frontmatter.description} />
    <meta property="og:site_name" content="Faizan Shaik Portfolio" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={frontmatter.title} />
    <meta
      property="article:published_time"
      content={new Date(frontmatter.date).toISOString()}
    />
    {
      frontmatter.tags?.map((tag: string) => (
        <meta property="article:tag" content={tag} />
      ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={pageUrl} />
    <meta name="twitter:title" content={frontmatter.title} />
    <meta name="twitter:description" content={frontmatter.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={frontmatter.title} />
    <meta name="twitter:creator" content="@fyzanshaik" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: frontmatter.title,
        description: frontmatter.description,
        datePublished: new Date(frontmatter.date).toISOString(),
        author: {
          '@type': 'Person',
          name: 'Faizan Shaik',
          url: 'https://fyzanshaik.in',
        },
        keywords: frontmatter.tags?.join(', '),
        url: pageUrl,
      })}
    />

    <link
      rel="preload"
      href="/fonts/geist-sans.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/geist-mono.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/tap_03.wav"
      as="fetch"
      type="audio/wav"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/tap_05.wav"
      as="fetch"
      type="audio/wav"
      crossorigin="anonymous"
    />

    <script is:inline>
      (function () {
        function applyTheme() {
          const theme =
            localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light');
          if (theme === 'dark') {
            document.documentElement.classList.add('dark');
            document.documentElement.style.colorScheme = 'dark';
          } else {
            document.documentElement.classList.remove('dark');
            document.documentElement.style.colorScheme = 'light';
          }
        }

        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    {
      GA_ID && (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
          />
          <script
            is:inline
            set:html={`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '${GA_ID}');
          `}
          />
        </>
      )
    }

    <ClientRouter />
  </head>
  <body>
    <NavBar />

    <div id="fixed-buttons" class="fixed bottom-4 right-4 z-50 flex gap-2">
      <button
        id="back-to-top"
        class="w-11 h-11 rounded-full bg-[var(--bg-surface)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--accent)] hover:text-[var(--accent-fg)] hover:border-[var(--accent)] transition-[color,background-color,border-color,transform] duration-150 ease-[var(--ease-geist)] opacity-0 pointer-events-none shadow-lg backdrop-blur-sm hover:scale-110"
        style="box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -2px rgba(0, 0, 0, 0.2);"
        aria-label="Back to top"
      >
        <svg
          class="w-5 h-5 mx-auto"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
        </svg>
      </button>
    </div>

    <div
      id="progress-bar-mobile"
      class="md:hidden fixed top-0 left-0 w-full h-1 bg-[var(--border)] z-40"
    >
      <div
        id="progress-fill-mobile"
        class="h-full bg-[var(--accent)] transition-[width] duration-150"
        style="width: 0%"
      >
      </div>
    </div>

    <main class="pt-12 pb-20 md:pl-24">
      <div class="mx-auto max-w-6xl px-5 sm:px-6">
        <a
          id="back-link"
          href="/"
          class="mb-10 inline-flex items-center gap-2 label-14 text-[var(--text-secondary)] transition-colors hover:text-[var(--accent)]"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          <span id="back-link-text">Back to Home</span>
        </a>
        <script is:inline>
          (function () {
            function updateBackLink() {
              const backLink = document.getElementById('back-link');
              const backText = document.getElementById('back-link-text');
              if (!backLink || !backText) return;

              const prevPage = sessionStorage.getItem('prev-page');
              const referrer = document.referrer;

              const cameFromBlog =
                (prevPage && prevPage.includes('/blog')) ||
                (referrer && referrer.includes('/blog'));

              if (cameFromBlog) {
                backLink.href = '/blog';
                backText.textContent = 'Back to Blog';
              } else {
                backLink.href = '/';
                backText.textContent = 'Back to Home';
              }
            }

            updateBackLink();
            document.addEventListener('astro:page-load', updateBackLink);
          })();
        </script>

        <div
          class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_220px] lg:items-start"
        >
          <article class="min-w-0">
            <header class="mb-10 border-b border-[var(--border)] pb-8">
              <div
                class="mb-5 flex flex-wrap items-center gap-x-3 gap-y-2 label-13 text-[var(--text-tertiary)]"
              >
                <time class="tabular">{formatDate(frontmatter.date)}</time>
                <span aria-hidden="true">/</span>
                <span id="reading-time" class="tabular">calculating…</span>
              </div>

              <h1 class="heading-48 mb-4 max-w-3xl text-[var(--text-primary)]">
                {frontmatter.title}
              </h1>
              <p class="max-w-2xl copy-18 text-[var(--text-secondary)]">
                {frontmatter.description}
              </p>

              {
                frontmatter.tags && frontmatter.tags.length > 0 && (
                  <div class="mt-6 flex flex-wrap gap-2">
                    {frontmatter.tags.map((tag: string) => (
                      <span class="rounded-sm border border-[var(--border)] bg-[var(--bg-fill)] px-2 py-1 font-mono label-12 text-[var(--text-secondary)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )
              }
            </header>

            <div id="blog-content" class="prose">
              <slot />
            </div>
          </article>

          <aside
            id="article-outline"
            class="sticky top-8 hidden max-h-[calc(100vh-4rem)] overflow-auto border-l border-[var(--border)] pl-5 lg:block"
            aria-label="Article outline"
          >
            <p
              class="mb-3 label-12 font-mono uppercase text-[var(--text-tertiary)]"
            >
              On this page
            </p>
            <nav id="toc-list" class="space-y-2"></nav>
          </aside>
        </div>
      </div>
    </main>

    <script is:inline>
      (function () {
        const backToTopButton = document.getElementById('back-to-top');

        function toggleBackToTop() {
          if (window.scrollY > 300) {
            backToTopButton.style.opacity = '1';
            backToTopButton.style.pointerEvents = 'auto';
          } else {
            backToTopButton.style.opacity = '0';
            backToTopButton.style.pointerEvents = 'none';
          }
        }

        function scrollToTop() {
          window.scrollTo({
            top: 0,
            behavior: 'smooth',
          });
        }

        window.addEventListener('scroll', toggleBackToTop, { passive: true });
        backToTopButton.addEventListener('click', scrollToTop);

        toggleBackToTop();
      })();
    </script>

    <script>
      function calculateReadingTime() {
        const content = document.getElementById('blog-content');
        if (content) {
          const text = content.innerText || content.textContent || '';
          const wordCount = text.trim().split(/\s+/).length;
          const wordsPerMinute = 200;
          const minutes = Math.ceil(wordCount / wordsPerMinute);
          const readingTimeEl = document.getElementById('reading-time');
          if (readingTimeEl) {
            readingTimeEl.textContent = `${minutes} min read`;
          }
        }
      }

      function updateProgressBar() {
        const windowHeight = window.innerHeight;
        const documentHeight = document.documentElement.scrollHeight;
        const scrollTop = window.scrollY || document.documentElement.scrollTop;
        const scrollPercent =
          (scrollTop / (documentHeight - windowHeight)) * 100;

        const progressFillMobile = document.getElementById(
          'progress-fill-mobile'
        );
        if (progressFillMobile) {
          progressFillMobile.style.width = `${Math.min(100, Math.max(0, scrollPercent))}%`;
        }
      }

      const rIC =
        (window as any).requestIdleCallback ||
        function (cb: any) {
          setTimeout(
            () => cb({ didTimeout: true, timeRemaining: () => 0 }),
            120
          );
        };

      const initIdle = () => {
        calculateReadingTime();
        updateProgressBar();
      };

      rIC(initIdle);
      document.addEventListener('astro:page-load', () => rIC(initIdle));

      window.addEventListener('scroll', updateProgressBar, { passive: true });
    </script>

    <AudioSystem />
    <script>
      function slugifyHeading(text: string) {
        return text
          .toLowerCase()
          .trim()
          .replace(/[^\w\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-');
      }

      function setupArticleOutline() {
        const content = document.getElementById('blog-content');
        const outline = document.getElementById('article-outline');
        const tocList = document.getElementById('toc-list');
        if (!content || !outline || !tocList) return;

        const headings = Array.from(content.querySelectorAll('h2, h3')).filter(
          heading => heading.textContent?.trim()
        );

        tocList.replaceChildren();

        if (headings.length === 0) {
          outline.classList.add('lg:hidden');
          return;
        }

        const usedIds = new Set<string>();

        headings.forEach(heading => {
          const text = heading.textContent?.trim() || '';
          let id = heading.id || slugifyHeading(text);
          let suffix = 2;

          while (usedIds.has(id)) {
            id = `${slugifyHeading(text)}-${suffix}`;
            suffix += 1;
          }

          usedIds.add(id);
          heading.id = id;

          const link = document.createElement('a');
          link.href = `#${id}`;
          link.textContent = text;
          link.className =
            heading.tagName === 'H3'
              ? 'toc-link block border-l-2 border-transparent pl-3 label-13 text-[var(--text-tertiary)] hover:text-[var(--accent)] transition-colors'
              : 'toc-link block border-l-2 border-transparent label-13 text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors';
          tocList.appendChild(link);
        });

        const previousObserver = (window as any).__articleOutlineObserver;
        previousObserver?.disconnect();

        const links = Array.from(
          tocList.querySelectorAll<HTMLAnchorElement>('.toc-link')
        );

        const setActiveLink = (id: string) => {
          links.forEach(link => {
            const active = link.hash === `#${id}`;
            link.classList.toggle('border-[var(--accent)]', active);
            link.classList.toggle('text-[var(--text-primary)]', active);
            link.classList.toggle('font-medium', active);
          });
        };

        const observer = new IntersectionObserver(
          entries => {
            const visible = entries
              .filter(entry => entry.isIntersecting)
              .sort(
                (a, b) => a.boundingClientRect.top - b.boundingClientRect.top
              );
            if (visible[0]) setActiveLink(visible[0].target.id);
          },
          { rootMargin: '-18% 0px -72% 0px' }
        );

        headings.forEach(heading => observer.observe(heading));
        (window as any).__articleOutlineObserver = observer;
        const hashHeading = headings.find(
          heading => heading.id === window.location.hash.slice(1)
        );
        const headingAboveViewport = [...headings]
          .filter(heading => heading.getBoundingClientRect().top <= 160)
          .at(-1);
        const initialHeading =
          hashHeading || headingAboveViewport || headings[0];
        if (initialHeading) setActiveLink(initialHeading.id);

        outline.classList.remove('lg:hidden');
      }

      function setupExcalidrawImages() {
        const content = document.getElementById('blog-content');
        if (!content) return;

        content.querySelectorAll('img').forEach(image => {
          const src = image.getAttribute('src') || '';
          if (!/excalidraw\.(svg|png|webp)$/i.test(src)) return;
          if ((image as HTMLElement).dataset.excalidrawSetup) return;

          (image as HTMLElement).dataset.excalidrawSetup = 'true';
          image.classList.add('excalidraw-render');

          const wrapper = document.createElement('figure');
          wrapper.className = 'excalidraw-frame';
          image.parentNode?.insertBefore(wrapper, image);
          wrapper.appendChild(image);

          if (image.alt) {
            const caption = document.createElement('figcaption');
            caption.textContent = image.alt;
            wrapper.appendChild(caption);
          }
        });
      }

      function loadMermaid() {
        const existing = (window as any).mermaid;
        if (existing) return Promise.resolve(existing);

        const scriptUrl =
          'https://cdn.jsdelivr.net/npm/mermaid@11.16.0/dist/mermaid.min.js';
        const existingScript = document.querySelector<HTMLScriptElement>(
          `script[src="${scriptUrl}"]`
        );

        return new Promise((resolve, reject) => {
          const script = existingScript || document.createElement('script');

          script.addEventListener('load', () => {
            const mermaid = (window as any).mermaid;
            if (mermaid) resolve(mermaid);
            else reject(new Error('Mermaid loaded without a global export'));
          });
          script.addEventListener('error', () => {
            reject(new Error('Failed to load Mermaid renderer'));
          });

          if (!existingScript) {
            script.src = scriptUrl;
            script.async = true;
            document.head.appendChild(script);
          }
        });
      }

      async function setupMermaidDiagrams() {
        const content = document.getElementById('blog-content');
        if (!content) return;

        const blocks = Array.from(
          content.querySelectorAll(
            'pre code.language-mermaid, pre code.mermaid'
          )
        );
        if (blocks.length === 0) return;

        const mermaid = await loadMermaid();

        mermaid.initialize({
          startOnLoad: false,
          securityLevel: 'strict',
          theme: document.documentElement.classList.contains('dark')
            ? 'dark'
            : 'default',
        });

        for (const [index, block] of blocks.entries()) {
          const pre = block.closest('pre');
          if (!pre || (pre as HTMLElement).dataset.mermaidSetup) continue;

          (pre as HTMLElement).dataset.mermaidSetup = 'true';
          const source = block.textContent || '';
          const frame = document.createElement('figure');
          frame.className = 'mermaid-frame';

          try {
            const { svg } = await mermaid.render(
              `mermaid-${Date.now()}-${index}`,
              source
            );
            frame.innerHTML = `<div class="mermaid-render">${svg}</div>`;
            pre.replaceWith(frame);
          } catch (error) {
            console.error('Failed to render Mermaid diagram:', error);
            pre.classList.add('mermaid-error');
          }
        }
      }

      function setupArticleEnhancements() {
        setupArticleOutline();
        setupExcalidrawImages();
        setupMermaidDiagrams();
      }

      setupArticleEnhancements();
      document.addEventListener('astro:page-load', setupArticleEnhancements);
    </script>

    <script>
      function setupCopyCodeButtons() {
        const blogContent = document.getElementById('blog-content');
        if (!blogContent) return;

        const codeBlocks = blogContent.querySelectorAll('pre');

        codeBlocks.forEach(codeBlock => {
          if ((codeBlock as HTMLElement).dataset.mermaidSetup) return;
          if ((codeBlock as HTMLElement).dataset.copySetup) return;
          (codeBlock as HTMLElement).dataset.copySetup = 'true';

          const parent = codeBlock.parentNode;
          if (!parent) return;

          const wrapper = document.createElement('div');
          wrapper.className = 'code-frame';

          const copyButton = document.createElement('button');
          copyButton.textContent = 'Copy';
          copyButton.className = 'copy-code-button';

          parent.insertBefore(wrapper, codeBlock);
          wrapper.appendChild(codeBlock);
          wrapper.appendChild(copyButton);

          copyButton.addEventListener('click', () => {
            const codeToCopy = codeBlock.querySelector('code')?.innerText || '';
            navigator.clipboard
              .writeText(codeToCopy)
              .then(() => {
                copyButton.textContent = 'Copied';
                setTimeout(() => {
                  copyButton.textContent = 'Copy';
                }, 2000);
              })
              .catch(err => {
                console.error('Failed to copy text: ', err);
                copyButton.textContent = 'Failed';
                setTimeout(() => {
                  copyButton.textContent = 'Copy';
                }, 2000);
              });
          });
        });
      }

      setupCopyCodeButtons();
      document.addEventListener('astro:page-load', setupCopyCodeButtons);
    </script>
  </body>
</html>

<style is:global>
  .prose {
    color: var(--text-primary);
    max-width: 760px;
    font-size: 17px;
    line-height: 1.75;
  }

  .prose h2 {
    font-size: 26px;
    font-weight: 600;
    line-height: 34px;
    letter-spacing: -0.04em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-top: 0.25rem;
    color: var(--text-primary);
    scroll-margin-top: 5rem;
  }

  .prose h3 {
    font-size: 21px;
    font-weight: 600;
    line-height: 28px;
    letter-spacing: -0.03em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    scroll-margin-top: 5rem;
  }

  .prose h1 {
    display: none;
  }

  .prose h2 + h3 {
    margin-top: 1.25rem;
  }

  .prose p {
    margin-bottom: 1.35rem;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose a:hover {
    color: var(--accent-hover);
  }

  .prose code {
    background-color: var(--bg-fill);
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-sm);
    font-size: 0.86em;
    font-family: var(--font-mono);
    color: var(--text-primary);
  }

  .prose pre {
    background-color: var(--bg-surface);
    padding: 1.25rem;
    border-radius: var(--radius-sm);
    overflow-x: auto;
    margin: 0;
    border: 1px solid var(--border);
    line-height: 1.65;
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
    color: var(--text-primary);
  }

  .prose ul,
  .prose ol {
    margin: 1.35rem 0;
    padding-left: 1.35rem;
    color: var(--text-secondary);
  }

  .prose ol {
    list-style-type: decimal;
    padding-left: 1.75rem;
  }

  .prose li {
    margin-bottom: 0.65rem;
    padding-left: 0.2rem;
  }

  .prose li::marker {
    color: var(--accent);
  }

  .prose li > p {
    margin-bottom: 0.5rem;
  }

  .prose blockquote {
    border-left: 3px solid var(--accent);
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 1.75rem 0;
    color: var(--text-secondary);
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent) 8%, transparent),
      transparent
    );
  }

  .prose .callout {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm);
    background: var(--bg-surface);
    padding: 1rem 1.125rem;
    color: var(--text-secondary);
  }

  .prose .callout > :last-child {
    margin-bottom: 0;
  }

  .prose img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    margin: 1.75rem 0;
    border: 1px solid var(--border);
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .prose strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .prose em {
    color: var(--text-secondary);
  }

  .code-frame,
  .mermaid-frame,
  .excalidraw-frame {
    position: relative;
    margin: 1.75rem 0;
  }

  .mermaid-frame,
  .excalidraw-frame {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-surface);
    padding: 1rem;
  }

  .mermaid-render {
    min-width: min-content;
    display: flex;
    justify-content: center;
