---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Timeline from '../components/Timeline.astro';
import '../styles/global.css';
---

<Layout>
  <NavBar />
  <main class="max-w-[1100px] mx-auto px-6 pt-16 pb-12 md:pt-28 md:pb-16">
    <div class="max-w-4xl">
      <h1 class="heading-40 mb-5 text-[var(--text-primary)]">$whoami?</h1>

      <div class="space-y-4 mb-8">
        <p class="copy-18 text-[var(--text-secondary)] max-w-3xl">
          Software engineer at <span class="text-[var(--text-primary)]"
            >Atlan</span
          >, based in Hyderabad. I build backend systems for data + AI products,
          work on cloud infrastructure, and care deeply about reliable,
          understandable software.
        </p>

        <p class="copy-18 text-[var(--text-secondary)] max-w-3xl">
          My work has moved across AI-powered research tools, Java/Spring
          backends, React/Node product surfaces, and now production data + AI
          systems at Atlan. I’m especially drawn to <span
            class="text-[var(--text-primary)]">Go</span
          >, <span class="text-[var(--text-primary)]">TypeScript</span>, <span
            class="text-[var(--text-primary)]">Python</span
          >, distributed systems, and performance work. Outside of work, I read
          research papers, tinker with embedded devices, and contribute to open
          source.
        </p>
      </div>
    </div>

    <div class="border-t border-[var(--border)] pt-10">
      <Timeline />
    </div>
  </main>
</Layout>
